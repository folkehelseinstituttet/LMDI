  ] ; # 
  fhir:effective [
     a fhir:DateTime ;
     fhir:v "2025-08-14T10:00:00+02:00"^^xsd:dateTime
  ] ; # 
  fhir:dosage [
     fhir:route [
       fhir:coding ( [
         fhir:system [
           fhir:v "urn:oid:2.16.578.1.12.4.1.1.7477"^^xsd:anyURI ;
           fhir:l <urn:oid:2.16.578.1.12.4.1.1.7477>
         ] ;
         fhir:code [ fhir:v "53" ] ;
