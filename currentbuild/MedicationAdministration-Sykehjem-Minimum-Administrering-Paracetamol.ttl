# - resource -------------------------------------------------------------------

<http://hl7.no/fhir/ig/lmdi/MedicationAdministration/Sykehjem-Minimum-Administrering-Paracetamol> a fhir:MedicationAdministration ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "Sykehjem-Minimum-Administrering-Paracetamol"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-medicationadministration"^^xsd:anyURI ;
       fhir:l <http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-medicationadministration>
     ] )
  ] ; # 
  fhir:status [ fhir:v "completed"] ; # 
  fhir:medication [
     a fhir:Reference ;
     fhir:l <http://hl7.no/fhir/ig/lmdi/Medication/Sykehjem-Minimum-Paracetamol-Merkevare> ;
     fhir:reference [ fhir:v "Medication/Sykehjem-Minimum-Paracetamol-Merkevare" ]
  ] ; # 
  fhir:subject [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Patient/Sykehjem-Minimum-Pasient> ;
     fhir:reference [ fhir:v "Patient/Sykehjem-Minimum-Pasient" ]
  ] ; # 
  fhir:context [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Encounter/Sykehjem-Minimum-Episode> ;
     fhir:reference [ fhir:v "Encounter/Sykehjem-Minimum-Episode" ]
  ] ; # 
  fhir:effective [
     a fhir:DateTime ;
     fhir:v "2025-03-10T08:00:00+01:00"^^xsd:dateTime
  ] ; # 
  fhir:dosage [
     fhir:dose [
       fhir:value [ fhir:v "500"^^xsd:decimal ] ;
       fhir:unit [ fhir:v "mg" ] ;
       fhir:system [
         fhir:v "http://unitsofmeasure.org"^^xsd:anyURI ;
         fhir:l <http://unitsofmeasure.org>
       ] ;
       fhir:code [ fhir:v "mg" ]
     ]
  ] . # 

