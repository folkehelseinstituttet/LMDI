@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<http://hl7.no/fhir/ig/lmdi/MedicationRequest/Scenario-B-Rekvirering> a fhir:MedicationRequest ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "Scenario-B-Rekvirering"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-medicationrequest"^^xsd:anyURI ;
       fhir:l <http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-medicationrequest>
     ] )
  ] ; # 
  fhir:status [ fhir:v "completed"] ; # 
  fhir:intent [ fhir:v "order"] ; # 
  fhir:medication [
     a fhir:Reference ;
     fhir:l <http://hl7.no/fhir/ig/lmdi/Medication/Scenario-B-Medisin> ;
     fhir:reference [ fhir:v "Medication/Scenario-B-Medisin" ]
  ] ; # 
  fhir:subject [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Patient/Scenario-B-Pasient> ;
     fhir:reference [ fhir:v "Patient/Scenario-B-Pasient" ]
  ] ; # 
  fhir:encounter [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Encounter/Scenario-B-Episode> ;
     fhir:reference [ fhir:v "Encounter/Scenario-B-Episode" ]
  ] ; # 
  fhir:authoredOn [ fhir:v "2025-03-09"^^xsd:date] ; # 
  fhir:requester [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Practitioner/Scenario-B-Helsepersonell> ;
     fhir:reference [ fhir:v "Practitioner/Scenario-B-Helsepersonell" ]
  ] ; # 
  fhir:reasonReference ( [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Condition/Scenario-B-Diagnose> ;
     fhir:reference [ fhir:v "Condition/Scenario-B-Diagnose" ]
  ] ) . # 

