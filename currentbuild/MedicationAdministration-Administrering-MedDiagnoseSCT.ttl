# - resource -------------------------------------------------------------------

<http://hl7.no/fhir/ig/lmdi/MedicationAdministration/Administrering-MedDiagnoseSCT> a fhir:MedicationAdministration ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "Administrering-MedDiagnoseSCT"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-medicationadministration"^^xsd:anyURI ;
       fhir:l <http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-medicationadministration>
     ] )
  ] ; # 
  fhir:status [ fhir:v "completed"] ; # 
  fhir:medication [
     a fhir:Reference ;
     fhir:l <http://hl7.no/fhir/ig/lmdi/Medication/Legemiddel-Varenummer> ;
     fhir:reference [ fhir:v "Medication/Legemiddel-Varenummer" ]
  ] ; # 
  fhir:subject [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Patient/Pasient-Med-DNR> ;
     fhir:reference [ fhir:v "Patient/Pasient-Med-DNR" ]
  ] ; # 
  fhir:context [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Encounter/Episode-Sykehus> ;
     fhir:reference [ fhir:v "Encounter/Episode-Sykehus" ]
  ] ; # 
  fhir:effective [
     a fhir:DateTime ;
     fhir:v "2025-07-13T14:48:47+02:00"^^xsd:dateTime
  ] ; # 
  fhir:reasonReference ( [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Condition/Diagnose-SNOMED-SCT> ;
     fhir:reference [ fhir:v "Condition/Diagnose-SNOMED-SCT" ]
  ] ) ; # 
  fhir:dosage [
     fhir:route [
       fhir:coding ( [
         fhir:system [
           fhir:v "urn:oid:2.16.578.1.12.4.1.1.7477"^^xsd:anyURI ;
           fhir:l <urn:oid:2.16.578.1.12.4.1.1.7477>
         ] ;
         fhir:code [ fhir:v "53" ] ;
         fhir:display [ fhir:v "Oral bruk" ]
       ] )
     ] ;
     fhir:dose [
       fhir:value [ fhir:v "750"^^xsd:decimal ] ;
       fhir:unit [ fhir:v "milligram" ] ;
       fhir:system [
         fhir:v "http://unitsofmeasure.org"^^xsd:anyURI ;
         fhir:l <http://unitsofmeasure.org>
