@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<http://hl7.no/fhir/ig/lmdi/Encounter/Sykehjem-Minimum-Episode> a fhir:Encounter ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "Sykehjem-Minimum-Episode"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-encounter"^^xsd:anyURI ;
       fhir:l <http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-encounter>
     ] )
  ] ; # 
  fhir:status [ fhir:v "in-progress"] ; # 
  fhir:class [
     fhir:system [
       fhir:v "http://terminology.hl7.org/CodeSystem/v3-ActCode"^^xsd:anyURI ;
       fhir:l <http://terminology.hl7.org/CodeSystem/v3-ActCode>
     ] ;
     fhir:code [ fhir:v "IMP" ] ;
     fhir:display [ fhir:v "inpatient encounter" ]
  ] ; # 
  fhir:serviceProvider [
     fhir:l <http://hl7.no/fhir/ig/lmdi/Organization/Sykehjem-Minimum-Avdeling> ;
     fhir:reference [ fhir:v "Organization/Sykehjem-Minimum-Avdeling" ]
  ] . # 

