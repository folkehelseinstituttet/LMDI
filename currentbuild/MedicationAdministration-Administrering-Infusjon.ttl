# - resource -------------------------------------------------------------------

<http://hl7.no/fhir/ig/lmdi/MedicationAdministration/Administrering-Infusjon> a fhir:MedicationAdministration ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "Administrering-Infusjon"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-medicationadministration"^^xsd:anyURI ;
       fhir:l <http://hl7.no/fhir/ig/lmdi/StructureDefinition/lmdi-medicationadministration>
     ] )
  ] ; # 
  fhir:status [ fhir:v "completed"] ; # 
  fhir:medication [
     a fhir:Reference ;
     fhir:l <https://fhir.legemidler.example.com/legemidler/0987654321> ;
     fhir:reference [ fhir:v "https://fhir.legemidler.example.com/legemidler/0987654321" ]
  ] ; # 
  fhir:subject [
     fhir:l <https://fhi.no/fhir/lmdi/pasient/12345678> ;
     fhir:reference [ fhir:v "https://fhi.no/fhir/lmdi/pasient/12345678" ]
  ] ; # 
  fhir:context [
     fhir:l <https://fhi.no/fhir/lmdi/institusjonsopphold/428ff23d-7a65-4c67-8059-6a1d07d287e3> ;
     fhir:reference [ fhir:v "https://fhi.no/fhir/lmdi/institusjonsopphold/428ff23d-7a65-4c67-8059-6a1d07d287e3" ]
  ] ; # 
  fhir:effective [
     a fhir:Period ;
     fhir:start [ fhir:v "2024-06-13T14:26:01+02:00"^^xsd:dateTime ] ;
     fhir:end [ fhir:v "2024-06-13T14:48:47+02:00"^^xsd:dateTime ]
  ] ; # 
  fhir:dosage [
     fhir:route [
       fhir:coding ( [
         a sct:47625008 ;
         fhir:system [
           fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
           fhir:l <http://snomed.info/sct>
         ] ;
         fhir:code [ fhir:v "47625008" ] ;
         fhir:display [ fhir:v "Intravenous route (qualifier value)" ]
       ] )
     ] ;
     fhir:dose [
       fhir:value [ fhir:v "4500"^^xsd:decimal ] ;
       fhir:unit [ fhir:v "mg" ] ;
       fhir:system [
         fhir:v "http://unitsofmeasure.org"^^xsd:anyURI ;
         fhir:l <http://unitsofmeasure.org>
       ] ;
       fhir:code [ fhir:v "mg" ]
     ] ;
     fhir:rate [
       a fhir:Ratio ;
       fhir:numerator [
         fhir:value [ fhir:v "8"^^xsd:decimal ] ;
         fhir:system [
           fhir:v "http://unitsofmeasure.org"^^xsd:anyURI ;
           fhir:l <http://unitsofmeasure.org>
         ] ;
         fhir:code [ fhir:v "mL" ]
       ] ;
       fhir:denominator [
         fhir:value [ fhir:v "1"^^xsd:decimal ] ;
         fhir:system [
           fhir:v "http://unitsofmeasure.org"^^xsd:anyURI ;
           fhir:l <http://unitsofmeasure.org>
         ] ;
         fhir:code [ fhir:v "min" ]
       ]
     ]
  ] . # 

